{
  "title": "SLO Burn Rate (Day 23)",
  "uid": "day23-slo",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "type": "stat", "title": "Error Budget Remaining (%)",
      "id": 1, "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "100 * (1 - (sum(increase(inference_requests_total{status=\"error\"}[30d])) / sum(increase(inference_requests_total[30d])) / 0.005))",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "percent",
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null},
          {"color": "yellow", "value": 25},
          {"color": "green", "value": 50}
        ]}
      }}
    },
    {
      "type": "timeseries", "title": "Burn Rate (multiple windows)",
      "id": 2, "gridPos": {"x": 8, "y": 0, "w": 16, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "inference:fail_ratio:rate5m  / 0.005", "legendFormat": "5m  burn", "refId": "A"},
        {"expr": "inference:fail_ratio:rate30m / 0.005", "legendFormat": "30m burn", "refId": "B"},
        {"expr": "inference:fail_ratio:rate1h  / 0.005", "legendFormat": "1h  burn", "refId": "C"},
        {"expr": "inference:fail_ratio:rate6h  / 0.005", "legendFormat": "6h  burn", "refId": "D"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {
        "thresholdsStyle": {"mode": "line"}
      },
      "thresholds": {"mode": "absolute", "steps": [
        {"color": "green", "value": null},
        {"color": "yellow", "value": 6},
        {"color": "red", "value": 14.4}
      ]}}}
    },
    {
      "type": "table", "title": "Active Alerts",
      "id": 3, "gridPos": {"x": 0, "y": 6, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "ALERTS{alertstate=\"firing\"}", "refId": "A", "format": "table", "instant": true}]
    }
  ]
}
